# Required at runtime + build time. Set in Vercel project env for prod.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Project ref used to scope sign-out cookie clear (without this set, only
# supabase.auth.signOut() runs — which is usually enough).
NEXT_PUBLIC_SUPABASE_PROJECT_REF=replace-with-project-ref

# Used by build-time URL validation; should match deployed origin in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase 2.2 — service-role Supabase key for ingest API endpoints. Bypasses
# RLS — never expose to the client. Vercel env var, server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Phase 2.2 — upload session JWT (HS256, 15-min TTL).
# Generate with: openssl rand -hex 32
UPLOAD_SESSION_JWT_SECRET=

# Phase 2.3 — base URL the cli-auth page advertises to users in
# instructions and copy-paste blocks. Should match the deployed dashboard
# origin (defaults to https://autopilot.dev in prod).
NEXT_PUBLIC_AUTOPILOT_BASE_URL=http://localhost:3000

# Phase 3 + Phase 4 — canonical public base URL.
#
# AUTOPILOT_PUBLIC_BASE_URL is read by:
#   - Phase 3 entitlement gate (upgrade URL in 402 responses)
#   - Phase 4 assertSameOrigin guard on cookie-authenticated routes
#   - Phase 4 CLI loopback CORS (Access-Control-Allow-Origin)
#   - Phase 4 Stripe checkout/portal redirect URLs
#
# Phase 4 also unifies the CLI's older AUTOPILOT_DASHBOARD_BASE_URL with
# this canonical name (deprecated alias still accepted with warning).
AUTOPILOT_PUBLIC_BASE_URL=https://autopilot.dev

# Phase 3 — Stripe API keys + webhook signing secret.
# STRIPE_SECRET_KEY: sk_live_... (or sk_test_... in dev)
# STRIPE_WEBHOOK_SECRET: whsec_... — copied from the Stripe dashboard webhook
# config that points at https://autopilot.dev/api/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Phase 3 — 4 Stripe Price IDs for the (tier, interval) matrix.
# Create Products + Prices in the Stripe dashboard; copy each price_... here.
STRIPE_PRICE_SMALL_MONTHLY=
STRIPE_PRICE_SMALL_YEARLY=
STRIPE_PRICE_MID_MONTHLY=
STRIPE_PRICE_MID_YEARLY=

# Phase 5.4 — WorkOS SSO setup.
# WORKOS_API_KEY: sk_live_... (or sk_test_... in dev). Used by the setup
#   route (organizations.createOrganization, adminPortal.generateLink) and
#   disconnect route (sso.deleteConnection).
# WORKOS_WEBHOOK_SECRET: whsec_... — copied from the WorkOS dashboard
#   webhook config that points at https://autopilot.dev/api/workos/webhook.
WORKOS_API_KEY=
WORKOS_WEBHOOK_SECRET=

# Phase 5.6 — WorkOS SSO sign-in.
# WORKOS_CLIENT_ID: client_... from the WorkOS dashboard (required by
#   workos.sso.getAuthorizationUrl and getProfileAndToken).
# SSO_STATE_SIGNING_SECRET: ≥32-byte secret (hex or utf8). Signs the
#   sso_state cookie value; module-load validation refuses to start if
#   shorter. Generate with: openssl rand -hex 32.
WORKOS_CLIENT_ID=
SSO_STATE_SIGNING_SECRET=
