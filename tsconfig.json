{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "presets/**/*.ts"],
  "exclude": ["node_modules", "dist", "apps/**"]
}
