{
  "name": "@delegance/claude-autopilot",
  "version": "2.3.0",
  "type": "module",
  "description": "Claude Code automation pipeline: spec → plan → implement → validate → PR",
  "keywords": [
    "claude",
    "autopilot",
    "ai",
    "pipeline",
    "code-review",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axledbetter/claude-autopilot.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "autopilot": "bin/autopilot.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "files": [
    "bin/",
    "src/",
    "presets/",
    "skills/",
    "scripts/test-runner.mjs",
    "scripts/autoregress.ts",
    "tests/snapshots/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node scripts/test-runner.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "autoregress": "tsx scripts/autoregress.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "ajv": "^8",
    "dotenv": ">=16",
    "js-yaml": "^4",
    "minimatch": ">=9",
    "openai": ">=4",
    "tsx": ">=4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "typescript": "^5"
  }
}
