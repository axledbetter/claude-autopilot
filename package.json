{
  "name": "@delegance/guardrail",
  "version": "3.8.0",
  "type": "module",
  "description": "Static rules + LLM code review pipeline: risk-ranked files, diff mode, SARIF, auto-fix",
  "keywords": [
    "guardrail",
    "code-review",
    "ai",
    "static-analysis",
    "sarif",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axledbetter/guardrail.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "guardrail": "bin/guardrail.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "files": [
    "bin/",
    "src/",
    "presets/",
    "skills/",
    "scripts/test-runner.mjs",
    "scripts/autoregress.ts",
    "tests/snapshots/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node scripts/test-runner.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "autoregress": "tsx scripts/autoregress.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "ajv": "^8",
    "dotenv": ">=16",
    "js-yaml": "^4",
    "minimatch": ">=9",
    "openai": ">=4",
    "tsx": ">=4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "typescript": "^5"
  }
}
